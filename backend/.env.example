# MongoDB Atlas connection string
# Create a free cluster at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nutrifit?retryWrites=true&w=majority

# Server port (5001 recommended on macOS — 5000 is used by AirPlay)
PORT=5001

# Environment
NODE_ENV=development

# Vercel frontend URL (for CORS on Render)
# FRONTEND_URL=https://nutri-fit-theta.vercel.app
